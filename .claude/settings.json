{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit.sh\" >&2 || exit 2",
            "statusMessage": "Checking for sensitive files before commit"
          }
        ]
      }
    ]
  }
}
